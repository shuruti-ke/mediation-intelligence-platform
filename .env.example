# Mediation Intelligence Platform - Environment Variables
# Copy to .env and fill in values

# Database (PostgreSQL)
DATABASE_URL=postgresql://mediation:mediation_secret@localhost:5432/mediation_platform

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT / Auth
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Jitsi (managed or self-hosted)
JITSI_DOMAIN=meet.jit.si
# For private deployment: JITSI_APP_ID, JITSI_APP_SECRET

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Phase 3: Documents & AI
STORAGE_PATH=./uploads
OPENAI_API_KEY=
LAWS_AFRICA_API_KEY=
TAUSI_API_KEY=
