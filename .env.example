# Mediation Intelligence Platform - Environment Variables
# Copy to .env and fill in values

# Database (PostgreSQL)
DATABASE_URL=postgresql://mediation:mediation_secret@localhost:5432/mediation_platform

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT / Auth
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Jitsi / JaaS (8x8)
JITSI_DOMAIN=meet.jit.si
JITSI_APP_ID=                    # JaaS App ID (e.g. vpaas-magic-cookie-xxx)
JITSI_APP_SECRET=                # JaaS App Secret for JWT signing

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Phase 3: Documents & AI
STORAGE_PATH=./uploads
OPENAI_API_KEY=
LAWS_AFRICA_API_KEY=
TAUSI_API_KEY=
