# Mediation Intelligence Platform - Environment Variables
# Copy to .env and fill in values

# Database (PostgreSQL)
DATABASE_URL=postgresql://mediation:mediation_secret@localhost:5432/mediation_platform
SCHEMA_MANAGEMENT_MODE=runtime   # runtime | alembic

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT / Auth
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Jitsi / JaaS (8x8) - set in Render for video rooms
JITSI_DOMAIN=meet.jit.si
JAAS_API_KEY_ID=                # API Key ID (kid in JWT header)
JAAS_APP_ID=                    # App ID (e.g. vpaas-magic-cookie-xxx)
JAAS_PRIVATE_KEY=               # RSA private key PEM (use \n for newlines in env)

# CORS (comma-separated; production URL is always allowed in code)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://mediation-intelligence-platform.vercel.app

# Phase 3: Documents & AI
STORAGE_PATH=./uploads
OPENAI_API_KEY=
LAWS_AFRICA_API_KEY=
TAUSI_API_KEY=
